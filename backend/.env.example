# ──────────────────────────────────────────────────────────────
# Portfolio backend — environment template.
# Copy this file to `.env` (in the same folder) and fill in.
# NEVER commit `.env` to git.
# ──────────────────────────────────────────────────────────────

# ── Gmail SMTP ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address (the account that will SEND the email).
SMTP_USER=hriteshsingha@gmail.com

# Gmail App Password — 16-character code, NOT your normal Gmail password.
# Generate one at:  https://myaccount.google.com/apppasswords
# (You must have 2-Step Verification enabled on your Google account.)
SMTP_PASSWORD=your-16-char-app-password

# ── Mail metadata ────────────────────────────────────────────
# Inbox that receives the contact-form messages (defaults to SMTP_USER).
MAIL_TO=hriteshsingha@gmail.com
MAIL_FROM_NAME=Portfolio Contact Form

# ── CORS (comma-separated origins allowed to POST) ───────────
# Add your local dev origins + your deployed frontend origin.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ── Rate limiting (per client IP) ────────────────────────────
# slowapi syntax: "<count>/<period>"  → 5/minute, 20/hour, etc.
RATE_LIMIT=5/minute

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
